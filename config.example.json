{
  "principal_env": "IDENTITY_BROKER_PRINCIPAL",
  "lease": {
    "default_ttl_seconds": 120,
    "maximum_ttl_seconds": 900
  },
  "identities": {
    "marksignals": {
      "allowed_principals": ["marksignals-agent"],
      "providers": {
        "github": {
          "command": "docker",
          "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "-e", "GITHUB_TOOLS", "ghcr.io/github/github-mcp-server"],
          "allowed_tools": ["get_file_contents", "issue_read", "create_issue"],
          "env": {
            "GITHUB_PERSONAL_ACCESS_TOKEN": "${MARKSIGNALS_GITHUB_TOKEN}",
            "GITHUB_TOOLS": "${MARKSIGNALS_GITHUB_TOOLS}"
          }
        },
        "outlook": {
          "command": "node",
          "args": ["/absolute/path/to/your-graph-mcp-server.js"],
          "allowed_tools": ["get_profile", "search_messages", "send_email"],
          "env": {
            "MICROSOFT_GRAPH_ACCESS_TOKEN": "${MARKSIGNALS_OUTLOOK_TOKEN}"
          }
        }
      }
    },
    "runcue": {
      "allowed_principals": ["runcue-agent"],
      "providers": {
        "github": {
          "command": "docker",
          "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "-e", "GITHUB_TOOLS", "ghcr.io/github/github-mcp-server"],
          "allowed_tools": ["get_file_contents", "issue_read"],
          "env": {
            "GITHUB_PERSONAL_ACCESS_TOKEN": "${RUNCUE_GITHUB_TOKEN}",
            "GITHUB_TOOLS": "${RUNCUE_GITHUB_TOOLS}"
          }
        }
      }
    }
  }
}
