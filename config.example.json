{
  "principal_env": "IDENTITY_BROKER_PRINCIPAL",
  "lease": {
    "default_ttl_seconds": 120,
    "maximum_ttl_seconds": 900
  },
  "identities": {
    "brand-a": {
      "allowed_principals": ["brand-a-agent"],
      "providers": {
        "github": {
          "command": "docker",
          "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "-e", "GITHUB_TOOLS", "ghcr.io/github/github-mcp-server"],
          "allowed_tools": ["get_file_contents", "issue_read", "create_issue"],
          "env": {
            "GITHUB_PERSONAL_ACCESS_TOKEN": "${BRAND_A_GITHUB_TOKEN}",
            "GITHUB_TOOLS": "${BRAND_A_GITHUB_TOOLS}"
          }
        },
        "outlook": {
          "command": "node",
          "args": ["/absolute/path/to/your-graph-mcp-server.js"],
          "allowed_tools": ["get_profile", "search_messages", "send_email"],
          "env": {
            "MICROSOFT_GRAPH_ACCESS_TOKEN": "${BRAND_A_OUTLOOK_TOKEN}"
          }
        }
      }
    },
    "client-b": {
      "allowed_principals": ["client-b-agent"],
      "providers": {
        "github": {
          "command": "docker",
          "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "-e", "GITHUB_TOOLS", "ghcr.io/github/github-mcp-server"],
          "allowed_tools": ["get_file_contents", "issue_read"],
          "env": {
            "GITHUB_PERSONAL_ACCESS_TOKEN": "${CLIENT_B_GITHUB_TOKEN}",
            "GITHUB_TOOLS": "${CLIENT_B_GITHUB_TOOLS}"
          }
        }
      }
    }
  }
}
